# Configuration for Docker UPnP Sync
# Copy this file to /etc/docker-upnp-sync/config.env and modify as needed.

# Path to the state file where managed ports are recorded.
# STATE_FILE="/var/lib/docker-upnp-sync/state.json"

# Path to the log file (when not managed by systemd, output goes here).
# LOG_FILE="/var/log/docker-upnp-sync.log"

# The interval in seconds between each check for container changes.
CHECK_INTERVAL=60

# The description attached to UPnP entries on the router.
UPNP_DESCRIPTION="Docker-UPnP-Sync"
